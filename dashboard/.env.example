# Supabase — mismas credenciales que el backend
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_KEY=tu_anon_key_aqui

# Contraseña para acceder al dashboard
# Cambiá "admin" por una contraseña segura
VITE_DASHBOARD_PASSWORD=admin
